{
  "schemaVersion": "1.0.0",
  "name": "AIMailer - Daily AI Tooling Roundup",
  "slug": "aimailer",
  "summary": "Automated daily email that summarizes ~12 recent articles about AI tools, agentic systems, and model releases for AI developers.",
  "version": "1.1.0",
  "license": "proprietary",
  "status": "production",
  "goals": [
    "Deliver a daily curated email of ~12 relevant AI tooling/model updates",
    "Automate fetch → dedupe → summarize → rank → email pipeline",
    "Prioritise high-signal official releases and dev-focused tooling updates",
    "Prevent duplicate articles with intelligent tracking"
  ],
  "primary_features": [
    "RSS/API/Local-search fetchers (Perplexica, SEARXNG)",
    "Readability-style extraction and LLM summarization (2–3 sentences + why devs care)",
    "Deduping, scoring and selection of top ~12 items with source diversity",
    "HTML email composition and automated sending via AWS SQS + SMTP",
    "Duplicate article prevention with 30-day tracking",
    "Multiple recipient support"
  ],
  "secondary_features": [
    "Source diversity algorithm (round-robin selection)",
    "Clean text extraction (filters JavaScript/JSON noise)",
    "AWS SQS queuing for reliable email delivery",
    "Automated scheduling via cron jobs",
    "Comprehensive logging and monitoring",
    "Article cache management utilities"
  ],
  "tech_stack": {
    "language": "python",
    "http_clients": "requests",
    "html_extraction": "custom regex-based extractor",
    "llm_client": "ollama (primary) / openai (fallback)",
    "email": "AWS SQS + SMTP (Gmail)",
    "scheduler": "cron",
    "queue": "AWS SQS",
    "cache": "JSON file-based article tracking",
    "dependencies": ["requests", "beautifulsoup4", "pyyaml", "pytest", "feedparser", "python-dateutil", "boto3"]
  },
  "security_considerations": [
    "API keys and SMTP credentials stored in environment variables",
    "HTML content sanitized during extraction",
    "Rate-limited external requests",
    "Respects source terms of service and robots.txt"
  ],
  "development_state": {
    "scaffold": "completed",
    "implementation": "completed",
    "testing": "completed",
    "deployment": "production",
    "notes": "Fully operational system with daily delivery and duplicate prevention"
  },
  "sources": [
    "https://openai.com/blog/rss.xml",
    "https://blog.google/technology/developers/rss/",
    "https://github.blog/feed/",
    "https://huggingface.co/blog/feed.xml",
    "https://aws.amazon.com/blogs/machine-learning/feed/",
    "https://blog.langchain.dev/feed/"
  ],
  "keywords": ["mcp", "agent", "cli", "opencode", "gemini", "gpt-5.1", "ai", "llm", "model", "langchain", "huggingface"],
  "schedule": "Daily 08:00",
  "recipients": [
    "stephen.z.phillips@sparktsl.com",
    "stephen.phillips.work@gmail.com"
  ],
  "architecture": {
    "overview": "Fetcher -> Tracker -> Extractor -> Summarizer -> Selector -> Composer -> SQS Queue -> SMTP Sender",
    "components": {
      "fetcher": { "description": "Fetch articles from RSS feeds and local search", "implementation": "feedparser + requests", "files": ["fetchers.py"], "status": "completed" },
      "tracker": { "description": "Track sent articles and prevent duplicates", "implementation": "JSON file-based cache with 30-day retention", "files": ["tracker.py"], "status": "completed" },
      "extractor": { "description": "Extract clean article text from HTML", "implementation": "custom regex-based cleaner", "files": ["extractor.py"], "status": "completed" },
      "summarizer": { "description": "Call LLM to summarise articles", "implementation": "ollama + openai fallback", "files": ["summarizer.py"], "status": "completed" },
      "selector": { "description": "Dedupe, score and select top items with source diversity", "implementation": "round-robin source selection", "files": ["selector.py"], "status": "completed" },
      "composer": { "description": "Compose HTML email", "implementation": "template-based HTML generation", "files": ["composer.py"], "status": "completed" },
      "queue": { "description": "AWS SQS message queue", "implementation": "boto3 SQS client", "files": ["sender.py"], "status": "completed" },
      "processor": { "description": "Process SQS queue and send emails", "implementation": "SMTP via Gmail", "files": ["process_email_queue.py"], "status": "completed" }
    }
  },
  "infrastructure": {
    "type": "cron jobs + AWS SQS",
    "schedule": {
      "generation": "0 8 * * * (Daily 8 AM)",
      "processing": "*/15 * * * * (every 15 minutes)"
    },
    "aws_resources": {
      "sqs_queue": "https://sqs.us-east-1.amazonaws.com/900211028177/aimailer-email-queue"
    },
    "files": ["run_aimailer.sh", "run_processor.sh", "process_email_queue.py", "manage_cache.py"]
  },
  "current_capabilities": [
    "Automated daily email generation and delivery",
    "Multi-source RSS feed processing (6 sources)",
    "AI-powered article summarization via Ollama",
    "Source diversity algorithm ensuring balanced content",
    "Clean text extraction filtering code/JSON noise",
    "Reliable email delivery via AWS SQS + SMTP",
