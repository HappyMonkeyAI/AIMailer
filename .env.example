# Copy this file to `.env` and fill in secret values. Do NOT commit `.env`.

# Ollama endpoint and model (defaults shown)
OLLAMA_URL="https://ollama.wifispark.net"
OLLAMA_MODEL="qwen2.5:7b-instruct-q4_K_M"

# Local search endpoints
PERPLEXICA_URL="http://10.0.10.46:3030/discover"
SEARXNG_URL="http://10.0.10.46:4040"

# OpenAI (optional) - leave empty if using Ollama/local models
OPENAI_API_KEY=""

# AWS SQS for email sending (preferred method)
SQS_QUEUE_URL="https://sqs.us-east-1.amazonaws.com/900211028177/aimailer-email-queue"
AWS_REGION="us-east-1"

# SMTP settings (fallback if SQS not available)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Dry-run output path
AIMAILER_DRYOUT="aimailer_last_dryrun.html"
